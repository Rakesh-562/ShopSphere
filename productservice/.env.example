JWT_SECRET_KEY=super-secret-jwt-super-secret-jwt-12345
ELASTICSEARCH_URL=https://localhost:9200
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=your_generated_elastic_password
# For local development you can often disable verification instead of wiring the CA cert.
# If you want verification enabled, set ELASTICSEARCH_CA_CERT to your generated http_ca.crt path.
ELASTICSEARCH_CA_CERT=C:\path\to\elasticsearch\config\certs\http_ca.crt
ELASTICSEARCH_VERIFY_CERTS=false
